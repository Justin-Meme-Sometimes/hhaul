<robot name="hamerschlag_haul">

  <material name="gray">
    <color rgba="0.2 0.2 0.2 1" />
  </material>

  <material name="blue">
    <color rgba="0.2 0.4 0.8 1" />
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" />
      <geometry>
        <box size="0.2 0.2 0.1" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>

  <link name="laser_frame">
    <visual>
      <origin xyz="0 0 0" />
      <geometry>
        <cylinder length="0.04" radius="0.04" />
      </geometry>
      <material name="gray" />
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link" />
    <child link="laser_frame" />
    <origin rpy="0 0 0" xyz="0 0 0.1" />
  </joint>

</robot>
